# ─── Jarvis Config ────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# Groq API (get a key at https://console.groq.com/keys)
GROQ_API_KEY=

# LLM model — swap freely. Examples:
#   llama-3.3-70b-versatile   (default, strong)
#   llama-3.1-8b-instant      (fast/cheap)
GROQ_MODEL=llama-3.3-70b-versatile

# Sampling
TEMPERATURE=0.6
MAX_TOKENS=1024

# Hotkey for hold-to-talk / tap-to-type. macOS Option key = "alt".
# Other options: cmd, ctrl, shift, f9, etc.
HOTKEY=alt

# Voice (Phase 2) — hold the hotkey to record, release to transcribe.
# Whisper model size: tiny, base, small, medium, large-v3. Bigger = more
# accurate but slower. "base" is a good CPU default on Apple Silicon.
WHISPER_MODEL=base
# Force a language (e.g. "en", "de") to skip auto-detect and speed things up.
# Leave empty to auto-detect.
WHISPER_LANGUAGE=
# Ignore holds shorter than this (seconds) — filters out accidental taps.
MIN_RECORD_SECONDS=0.35

# Persistent memory (Phase 3) — conversations survive an app restart,
# stored in a local SQLite file. Set to false for a blank slate every run.
MEMORY_ENABLED=true
MEMORY_DB_PATH=jarvis_memory.db

# Text-to-speech — off by default. Set to true to have Jarvis speak every
# reply (and the startup greeting) out loud.
TTS_ENABLED=false
# Fallback / default voice (edge-tts, free, no key). Browse options with
# `edge-tts --list-voices`. Examples: de-DE-KillianNeural, de-DE-ConradNeural.
TTS_VOICE=de-DE-KillianNeural

# ElevenLabs (optional, better quality) — leave both blank to just use the
# edge-tts voice above. Free tier: ~10k characters/month. Get a key at
# elevenlabs.io, then pick a voice in the Voice Library and copy its ID.
# Falls back to edge-tts automatically if synthesis fails at runtime
# (e.g. quota exhausted).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
