# ─── Jarvis Config ────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# Groq API (get a key at https://console.groq.com/keys)
GROQ_API_KEY=

# LLM model — swap freely. Examples:
#   llama-3.3-70b-versatile   (default, strong)
#   llama-3.1-8b-instant      (fast/cheap)
GROQ_MODEL=llama-3.3-70b-versatile

# Sampling
TEMPERATURE=0.6
MAX_TOKENS=1024

# Hotkey for hold-to-talk / tap-to-type. macOS Option key = "alt".
# Other options: cmd, ctrl, shift, f9, etc.
HOTKEY=alt

# Voice (Phase 2) — hold the hotkey to record, release to transcribe.
# Whisper model size: tiny, base, small, medium, large-v3. Bigger = more
# accurate but slower. "base" is a good CPU default on Apple Silicon.
WHISPER_MODEL=base
# Force a language (e.g. "en", "de") to skip auto-detect and speed things up.
# Leave empty to auto-detect.
WHISPER_LANGUAGE=
# Ignore holds shorter than this (seconds) — filters out accidental taps.
MIN_RECORD_SECONDS=0.35

# Persistent memory (Phase 3) — conversations survive an app restart,
# stored in a local SQLite file. Set to false for a blank slate every run.
MEMORY_ENABLED=true
MEMORY_DB_PATH=jarvis_memory.db

# Text-to-speech — off by default. Set to true to have Jarvis speak every
# reply (and the startup greeting) out loud.
TTS_ENABLED=false
# Fallback / default voice (edge-tts, free, no key). Browse options with
# `edge-tts --list-voices`. Examples: de-DE-KillianNeural, de-DE-ConradNeural.
TTS_VOICE=de-DE-KillianNeural

# ElevenLabs (optional, better quality) — leave both blank to just use the
# edge-tts voice above. Free tier: ~10k characters/month. Get a key at
# elevenlabs.io, then pick a voice in the Voice Library and copy its ID.
# Falls back to edge-tts automatically if synthesis fails at runtime
# (e.g. quota exhausted).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Voice tuning — higher stability = steadier/deeper delivery, less
# expressive; higher similarity_boost = closer to the original voice
# sample. Both 0.0-1.0. Uses eleven_multilingual_v2 (required for German).
ELEVENLABS_STABILITY=0.75
ELEVENLABS_SIMILARITY_BOOST=0.85

# Tools (Phase 1) — real system access: files, shell, app launcher,
# clipboard, browser, calendar, web search, screenshot+vision. The model
# decides on its own when to use these via function calling. Set to false
# to make Jarvis a plain chatbot again.
TOOLS_ENABLED=true
# Web search (Tavily, https://tavily.com — free tier available). Leave
# empty to skip registering the web_search tool entirely.
TAVILY_API_KEY=
# Vision-capable Groq model, used only by the see_screen tool.
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Proactivity layer (Phase 2) — Jarvis acts without being asked.
# Master switch; set to false to disable morning brief / GitHub watcher /
# idle nudge all at once.
PROACTIVITY_ENABLED=true

# Morning brief — daily summary (calendar, GitHub PRs, weather, tasks),
# spoken aloud (needs TTS_ENABLED=true) and shown in the dashboard.
MORNING_BRIEF_ENABLED=true
MORNING_BRIEF_TIME=07:30

# GitHub watcher — polls these repos and announces new/changed open PRs.
# Uses the `gh` CLI, so it needs `gh auth login` to already be done.
# Comma-separated "owner/repo" list; leave empty to disable.
GITHUB_WATCH_ENABLED=true
GITHUB_REPOS=
GITHUB_WATCH_INTERVAL_MINUTES=30

# Idle nudge — after this many minutes with no hotkey/typed interaction,
# Jarvis suggests a break. Re-arms the next time you interact.
IDLE_NUDGE_ENABLED=true
IDLE_NUDGE_MINUTES=120

# Weather for the morning brief (Open-Meteo, no API key needed). Leave
# both empty to skip the weather section entirely.
WEATHER_LATITUDE=
WEATHER_LONGITUDE=

# Optional markdown checklist file (lines like "- [ ] task") summarized
# in the morning brief as open tasks. Leave empty to skip.
TASKS_FILE=

# Structured memory (Phase 3) — a small JSON profile (projects, goals,
# daily patterns, preferences) extracted from conversation and fed back
# into every prompt, instead of just replaying raw chat history. Needs
# MEMORY_ENABLED=true (the profile is stored alongside the chat log).
PROFILE_ENABLED=true
# Cheap/fast model for the per-turn extraction call — doesn't need to be
# as capable as GROQ_MODEL, it's just pulling structured facts out of one exchange.
PROFILE_EXTRACTION_MODEL=llama-3.1-8b-instant
